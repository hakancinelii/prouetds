{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/vercel-handler.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/src/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/src/vercel-handler.ts"
    }
  ]
}